logging.basicConfig(level=logging.INFO, format='%(asctime)s | %(message)s')
logger = logging.getLogger("Ultra96DoubleHit")

BOT_TOKEN = ""
HF_TOKEN  = ""

DEVICE = "cuda"
DTYPE  = torch.float16

# ТЕГИ ДЛЯ ПРАВИЛЬНОЙ ФИЗИКИ (PONY)
PONY_TAGS = (
    "score_9, score_8_up, score_7_up, source_real, RAW photo, masterpiece, "
    "natural body physics, soft flesh indentation, realistic body weight, "
    "anatomical accuracy, perfectly modeled male and female organs, "
