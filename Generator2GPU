)

# ТЕГИ ДЛЯ КРАСИВОГО СВЕТА И ЛИЦА (REALVIS)
REAL_TAGS = (
    "masterpiece, ultra-detailed photorealistic portrait, Fujifilm GFX 100S, "
    "cinematic soft lighting, subsurface scattering, visible skin pores, "
    "extremely beautiful face, detailed symmetrical eyes, raw unretouched, "
    "natural skin texture, elegant composition"
)

NEG_PROMPT = (
    "score_4, score_5, score_6, source_anime, 3d, cgi, cartoon, plastic, doll, "
